<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <OutDirRoot>$(SolutionDir)bin</OutDirRoot>
    <IntDirRoot>$(SolutionDir).temp\$(MSBuildProjectName)\</IntDirRoot>
  </PropertyGroup>
  <PropertyGroup>
    <OutDir>$([MSBuild]::EnsureTrailingSlash('$(OutDirRoot)'))$(Platform)\$(Configuration)\</OutDir>
    <IntDir>$(IntDirRoot)$(Platform)\$(Configuration)\</IntDir>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <LanguageStandard>stdcpp23</LanguageStandard>
      <UseFullPaths>false</UseFullPaths>
    </ClCompile>
    <Midl>
      <OutputDirectory>$(IntDir)</OutputDirectory>
    </Midl>
    <Midl>
      <HeaderFileName>%(Filename).h</HeaderFileName>
    </Midl>
  </ItemDefinitionGroup>
</Project>